
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth.token.email == 'loganathans@vmkvec.edu.in';
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Any authenticated user can create their own profile
      allow create: if request.auth != null;
      // Users can only read and update their own profile
      allow read, update: if request.auth.uid == userId;
    }
    
    // Rules for the 'exams' collection
    match /exams/{examId} {
      // Any authenticated user can view the exams
      allow read: if request.auth != null;
      // Only an admin can create, update, or delete exams
      allow write: if isAdmin();
    }
    
    // Rules for the 'submissions' collection
    match /submissions/{submissionId} {
      // Any authenticated user can create a submission (i.e. submit a test)
      allow create: if request.auth != null;
      // Only an admin can read the submissions
      allow read: if isAdmin();
      // Nobody can update or delete submissions from the client
      allow update, delete: if false;
    }
  }
}
