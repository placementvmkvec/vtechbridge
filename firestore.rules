rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is the designated admin
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Exams can be read by any authenticated user, but only written by an admin.
    match /exams/{examId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users can read/write their own profile. Admins can read any profile.
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if isAdmin();
    }
    
    // Submissions can be created by any authenticated user (for themselves).
    // Admins can read all submissions for the dashboard.
    match /submissions/{submissionId} {
      allow create: if request.auth.uid == request.resource.data.userId;
      allow read: if isAdmin();
    }
  }
}