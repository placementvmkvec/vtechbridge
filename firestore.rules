
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Rules for exams collection
    match /exams/{examId} {
      // Allow any authenticated user to read exams.
      // This is necessary for users to see the exam list and take a test.
      allow read: if request.auth != null;

      // Only allow the admin to create, update, or delete exams.
      allow write: if isAdmin();
    }

    // Rules for users collection
    match /users/{userId} {
      // Admin can read all user documents.
      // A user can read or update their own document.
      allow read, update: if request.auth.uid == userId || isAdmin();
      
      // A new user can create their own user document upon signup.
      allow create: if request.auth.uid == userId;
    }

    // Rules for submissions collection
    match /submissions/{submissionId} {
        // Admin can read all submission documents.
        allow read: if isAdmin();
        
        // A user can only create a submission for themselves.
        allow create: if request.auth.uid == request.resource.data.userId;
    }
  }
}
