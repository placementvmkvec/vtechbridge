rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    match /exams/{examId} {
      // Allow any logged-in user to get a single exam or list all exams.
      // This is required for users to see the dashboard and start a test.
      allow get, list: if request.auth != null;
      
      // Only allow the admin to create, update, or delete exams.
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Allow a user to read their own profile, or allow the admin to read any profile.
      allow read: if request.auth.uid == userId || isAdmin();
      
      // Allow a user to only write to their own profile.
      allow write: if request.auth.uid == userId;
    }

    match /submissions/{submissionId} {
      // Only allow the admin to read all submission results.
      allow read: if isAdmin();

      // Allow any logged-in user to create a new submission.
      allow create: if request.auth != null;
      
      // Disallow updating or deleting submissions to maintain result integrity.
      allow update, delete: if false;
    }
  }
}
