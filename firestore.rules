
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Users:
    // - Authenticated users can read/update their own profile
    // - Admin can read all user profiles
    match /users/{userId} {
      allow read, update, create: if request.auth != null && request.auth.uid == userId;
      allow list: if isAdmin();
    }

    // Exams:
    // - Any authenticated user can read exams
    // - Only Admin can create, update, delete exams
    match /exams/{examId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Submissions:
    // - Authenticated users can create a submission for themselves
    // - Admin can read all submissions
    match /submissions/{submissionId} {
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow list, get: if isAdmin();
    }
  }
}
