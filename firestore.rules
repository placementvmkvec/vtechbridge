rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are completely open and are not secure.
    // They are intended for development purposes only.
    // Anyone can read, write, and delete any data in your database.
    // Before launching your application, you must replace these with
    // secure rules.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
