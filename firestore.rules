rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin role
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Exams: Users can read, Admins can write
    match /exams/{examId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users: Can manage their own profile, Admins can read all profiles
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId;
    }

    // Submissions: Users can create their own once, Admins can do anything
    match /submissions/{submissionId} {
      allow read, delete: if isAdmin();
      allow create: if request.auth != null && 
      !exists(/databases/$(database)/documents/submissions/$(request.resource.data.userId)_$(request.resource.data.examId));
      allow update: if false; // Submissions are immutable
    }
  }
}
