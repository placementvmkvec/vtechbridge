rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin user email
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Exams: Users can read, only admin can write.
    match /exams/{examId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users: Can manage their own profile. Admin can read all profiles.
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Submissions: Users can create their own. Admin can read all.
    match /submissions/{submissionId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }
  }
}
