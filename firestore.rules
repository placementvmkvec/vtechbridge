rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin role
    function isAdmin() {
      return request.auth.token.email == "loganathans@vmkvec.edu.in";
    }

    // Exams: Users can read, Admins can write
    match /exams/{examId} {
      allow get, list: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users: Can manage their own profile, Admins can read all profiles
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId;
    }

    // Submissions: Users can create their own once, Admins can read/delete
    match /submissions/{submissionId} {
      allow read, delete: if isAdmin();
      // A user can create a submission if they are authenticated and a submission for that user and exam doesn't already exist.
      // The submissionId is expected to be in the format: `${userId}_${examId}`
      allow create: if request.auth != null && !exists(path(submissionId));
      allow update: if false; // Submissions are immutable
    }
  }
}
