rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Admins can write exams, authenticated users can read them
    match /exams/{examId} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.token.email == 'loganathans@vmkvec.edu.in';
    }
  }
}
